<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/

    # Force HTTPS for API traffic, EXCEPT the device push path (/iclock/*),
    # which is internally rewritten into this directory but must stay HTTP.
    # THE_REQUEST holds the original request line, immune to internal rewrites.
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteCond %{THE_REQUEST} !\s/+iclock/ [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Don't rewrite files or directories
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# Deny access to sensitive files
<FilesMatch "^\.env|composer\.lock|composer\.json|\.git">
    Order allow,deny
    Deny from all
</FilesMatch>
